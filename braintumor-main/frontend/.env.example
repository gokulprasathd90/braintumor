# ─── Vite environment variables ───────────────────────────────────────────────
# All variables MUST be prefixed with VITE_ to be exposed to the browser bundle.
# Copy this file to .env.local for local development (never commit .env.local).

# Base URL of the Python AI service (Vite proxies /api → this URL in dev)
VITE_AI_SERVICE_URL=http://localhost:8000

# Application display name shown in the browser tab / header
VITE_APP_NAME=Brain Tumour Detection

# Feature flags
VITE_ENABLE_GRADCAM=true        # show Grad-CAM heatmap panel
VITE_ENABLE_BATCH=true          # enable batch prediction page
VITE_ENABLE_TRAINING=true       # enable training dashboard
VITE_ENABLE_DATASET_MANAGER=true

# API timeout in milliseconds (default 60s for training, 30s for inference)
VITE_API_TIMEOUT_MS=30000
VITE_TRAINING_TIMEOUT_MS=600000

# Polling interval for training status (ms)
VITE_TRAINING_POLL_INTERVAL_MS=3000
