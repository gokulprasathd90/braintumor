# This directory holds Docker Compose secret files.
# These files are git-ignored and must be created manually on each deployment host.
#
# Required files:
#   jwt_secret_key.txt        — JWT signing secret (64+ char random string)
#   db_encryption_key.txt     — Database encryption key (32+ char random string)
#
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))" > jwt_secret_key.txt
#   python -c "import secrets; print(secrets.token_hex(32))" > db_encryption_key.txt
