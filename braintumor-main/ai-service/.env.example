# ─── Server ───────────────────────────────────────────────────────────────────
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_ENV=development          # development | production
AI_SERVICE_DEBUG=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ─── Model paths ──────────────────────────────────────────────────────────────
SAVED_MODELS_DIR=./saved_models
ACTIVE_MODEL=efficientnet           # cnn | vgg16 | resnet50 | efficientnet

# ─── Image settings ───────────────────────────────────────────────────────────
IMAGE_SIZE=224                      # target width = height in pixels
IMAGE_CHANNELS=3

# ─── Classes ──────────────────────────────────────────────────────────────────
# Comma-separated list matching model output indices
CLASS_NAMES=glioma,meningioma,notumor,pituitary

# ─── Dataset paths ────────────────────────────────────────────────────────────
DATASET_RAW_DIR=./dataset/raw
DATASET_PROCESSED_DIR=./dataset/processed

# ─── Grad-CAM output ──────────────────────────────────────────────────────────
GRADCAM_OUTPUT_DIR=./gradcam_output

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
