# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
HOST=localhost
NODE_ENV=development           # development | production | test

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the React frontend — must match the origin sent by the browser
FRONTEND_URL=http://localhost:3000

# ─── File Upload ──────────────────────────────────────────────────────────────
# Directory where Multer saves incoming MRI image uploads
UPLOAD_DIR=../uploads

# ─── Dataset ──────────────────────────────────────────────────────────────────
DATASET_DIR=../dataset

# ─── Model Artefacts ──────────────────────────────────────────────────────────
# Path to the serialised EDN-SVM model JSON written by the pipeline
MODEL_PATH=./models/edn_svm.json

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to backend/)
DB_PATH=./database/brain_tumor.db

# ─── AI Service ───────────────────────────────────────────────────────────────
# Base URL of the Python FastAPI service — used by the bridge/proxy routes
AI_SERVICE_URL=http://localhost:8000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | http | debug
