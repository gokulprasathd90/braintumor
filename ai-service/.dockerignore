# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment — never copy into image
.venv/
venv/
env/

# Local environment file — secrets must not enter the image layer
.env

# Test artefacts
.pytest_cache/
.coverage
htmlcov/

# Dataset — mounted as a volume at runtime
dataset/raw/
dataset/processed/

# Model weights — mounted as a volume at runtime
saved_models/

# Grad-CAM output — mounted as a volume at runtime
gradcam_output/

# Logs
logs/
*.log

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Git
.git/
.gitignore
